@page "/login"
@using Microsoft.AspNetCore.Components.Authorization
@using static BlazorUI.Models.Auth
@inject NavigationManager NavigationManager
@inject IAuthServices IAuthServices
@inject AuthenticationStateProvider AuthProvider
@inject ILocalStorageService LocalStorageService


<div class="d-flex justify-content-center align-items-start vh-100 mt-5">
    <div class="card shadow-sm" style="width: 400px;">
        <div class="card-body">
            <h3 class="text-center mb-4">Login</h3>
            <h3>Login</h3>
            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText @bind-Value="loginModel.Email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <InputText @bind-Value="loginModel.Password" type="password" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary w-100">Ingresar</button>
                <a href="/" class="align-items-center">Regresar</a>
            </EditForm>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3 text-center">
                    @errorMessage
                </div>
            }
        </div>
    </div>
</div>


@code {
    private LoginDTO loginModel = new LoginDTO();
    private string? errorMessage;

    private async Task HandleLogin()
    {
        var resul = await IAuthServices.LoginAsync(loginModel);
        if (resul.Success)
        {

            var customProvider = (CustomAuthStateProvider)AuthProvider;
            await customProvider.NotifyUserAuthentication(resul.Data);
            var claims = JwtParser.ParseClaimsFromJwt(resul.Data.AccessToken);
            var role = claims.FirstOrDefault(c => c.Type == "role")?.Value;

            switch (role)
            {
                case "Admin":
                    NavigationManager.NavigateTo("/admin/dashborad");
                    break;
                case "Doctor":
                    NavigationManager.NavigateTo("/doctor/citas");
                    break;
                case "Patient":
                    NavigationManager.NavigateTo("/cliente/miscitas");
                    break;
                default:
                    NavigationManager.NavigateTo("/");
                    break;
            }

        }
        else
        {
            errorMessage = resul.Message;
        }
    }
    }

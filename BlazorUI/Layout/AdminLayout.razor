@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase
@inject CustomAuthStateProvider AuthStateProvider
@inject NavigationManager NavigationManager




<div class="d-flex">

    <AuthorizeView Roles="Admin">
        <div class="bg-dark text-white p-3" style="width:250px;">
            <h4 class="mb-4">Panel Admin</h4>
            <nav class="nav flex-column">
                <NavLink class="nav-link text-white" href="/usuarios">Usuarios</NavLink>
                <NavLink class="nav-link text-white" href="/citas">Citas</NavLink>
                <NavLink class="nav-link text-white" href="/reportes">Reportes</NavLink>
                <NavLink class="nav-link text-white" href="/">Home</NavLink>
            </nav>
        </div>
    </AuthorizeView>

    <div class="flex-grow-1">
        <nav class="navbar navbar-light bg-light px-3">
            <span class="navbar-brand">Administrador</span>
            <div class="ms-auto">
                <AuthorizeView>
                    <Authorized>
                        Bienvenido, @context.User.Identity?.Name
                        <button class="btn btn-outline-danger" @onclick="Logout">Logout</button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </nav>

        <div class="p-4">
            @Body
        </div>
    </div>
</div>

@code {

    private async Task Logout()
    {
        NavigationManager.NavigateTo("/logout");
    }
}
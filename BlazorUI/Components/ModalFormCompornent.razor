


<div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Title</h5>
                <button type="button" class="btn-close" @onclick="OnCancel"></button>
            </div>
            <div class="modal-body">
                @if (editContext is null)
                {
                    @ChildContent
                    <div class="mt-3 d-flex justify-content-end">
                        <button type="submit" class="btn btn-success me-2" @onclick="OnValidSubmit">Aceptar</button>
                        <button type="button" class="btn btn-secondary" @onclick="OnCancel">Cancelar</button>
                    </div>
                }
                else
                {
                    <EditForm EditContext="@editContext" OnValidSubmit="OnValidSubmit">
                        <ValidationSummary/>
                        @ChildContent
                        <div class="mt-3 d-flex justify-content-end">
                            <button type="submit" class="btn btn-success me-2">Aceptar</button>
                            <button type="button" class="btn btn-secondary" @onclick="OnCancel">Cancelar</button>
                            </div>
                        
                    </EditForm>
                }

                
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; }
    [Parameter] public object? Model { get; set; }
    [Parameter] public EditContext editContext { get; set; }
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public RenderFragment ChildContent { get; set; }

}
